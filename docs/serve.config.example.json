{
  "store": "s3://example-cometbft-archive?region=us-east-1",
  "prefix": "archive",
  "chain_id": "example-chain-1",
  "manifest_name": "manifest.json",
  "db_dir": "/var/lib/cometbft-archive/data",
  "db_backend": "goleveldb",
  "p2p_listen": "tcp://0.0.0.0:26656",
  "moniker": "cometbft-archive-1",
  "node_key_file": "/var/lib/cometbft-archive/config/node_key.json",
  "persistent_peers": [
    "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa@10.0.0.10:26656",
    "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb@10.0.0.11:26656"
  ],
  "request_limit": 32,
  "cold_workers": 8,
  "cold_manifest_cache_ttl": "5s",
  "request_timeout": "30s",
  "status_request_interval": "10s",
  "pex": false,
  "addr_book_strict": true,
  "metrics_listen": "127.0.0.1:26660",
  "safety_window": 100,
  "archive_interval": "30s",
  "prune_interval": "5m",
  "retain_blocks": 1000,
  "evidence_max_age_blocks": 0,
  "evidence_max_age_duration": "0s",
  "segment_blocks": 100,
  "compression": "gzip",
  "validation": "validator-set",
  "validator_set_rpc": "http://127.0.0.1:26657",
  "validator_set_timeout": "5s",
  "dry_run": true
}
